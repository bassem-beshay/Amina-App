{
  "terminal.integrated.env.windows": {
    "LANG": "ar_SA.UTF-8",
    "CHCP": "65001",
    "PYTHONIOENCODING": "utf-8"
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell (Arabic)",
  "terminal.integrated.profiles.windows": {
    "PowerShell (Arabic)": {
      "source": "PowerShell",
