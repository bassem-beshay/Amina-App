# ========================================
# 🔒 Environment Configuration Example
# ========================================
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER commit .env file to version control!

# ========================================
# 🌐 Environment Selection
# ========================================
# Options: development, staging, production
ENVIRONMENT=production

# ========================================
# 🔐 API Keys
# ========================================
# Google Services API Key
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your_google_api_key_here

# Firebase Crash Reporting API Key
FIREBASE_CRASH_KEY=your_firebase_crash_key_here

# ========================================
# 💳 Payment Gateway (PaySky)
# ========================================
# PaySky Merchant ID
PAYSKY_MERCHANT_ID=your_merchant_id_here

# PaySky API Key
PAYSKY_API_KEY=your_paysky_api_key_here

# ========================================
# 🌐 API Configuration (Optional - overrides defaults)
# ========================================
# API_BASE_URL=https://amina.bdcbiz.com
# WS_URL=wss://amina.bdcbiz.com

# ========================================
# 🛡️ Security Settings
# ========================================
# Enable logging (true/false) - should be false in production
ENABLE_LOGGING=false

# Debug mode (true/false)
DEBUG_MODE=false

# Certificate pinning (true/false)
ENABLE_CERT_PINNING=true

# ========================================
# 📱 Build Configuration
# ========================================
# Version code (increment for each release)
# VERSION_CODE=46

# Version name
# VERSION_NAME=1.0.46
